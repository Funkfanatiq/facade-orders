# Скопируйте в .env и заполните значения
# cp .env.example .env

# База данных (Render подставляет DATABASE_URL автоматически)
# DATABASE_URL=postgresql://...

# Flask
SECRET_KEY=your-secret-key

# Загрузка файлов к заказу (несколько PDF и т.д.)
# MAX_FILE_SIZE_MB=32          # один файл, по умолчанию 32
# MAX_CONTENT_LENGTH_MB=300   # весь запрос целиком, по умолчанию 300
# На Render (Docker): при очень тяжёлых загрузках можно поднять таймаут веб-сервиса:
# GUNICORN_TIMEOUT=600

# Почта Mail.ru — обязательно для отправки и получения писем
MAIL_USERNAME=ваш_почта@mail.ru
MAIL_PASSWORD=пароль_приложения
